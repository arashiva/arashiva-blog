---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-tag">
					<span class="dot"></span>
					<span>{SITE_TITLE.toLowerCase()} // est. 2026</span>
				</div>
				<h1>
					<span class="line">between the breath,</span>
					<span class="line dim">and the next.</span>
				</h1>
				<p class="hero-sub">{SITE_DESCRIPTION}</p>
				<div class="hero-rule"></div>
			</section>

			<section class="posts">
				<div class="section-head">
					<span class="label">recent</span>
					<span class="rule"></span>
					<span class="count">{posts.length.toString().padStart(2, '0')}</span>
				</div>

				<ul>
					{posts.map((post) => (
						<li>
							<a href={`${base}/blog/${post.id}/`}>
								<div class="row">
									<span class="row-title">{post.data.title}</span>
									<span class="row-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								{post.data.description && (
									<p class="row-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />

		<style>
			/* Sandy / paper-warm accents — only on the home page */
			:root {
				--cream: #ece1c7;
				--cream-soft: #d8cba8;
				--cream-faint: rgba(236, 225, 199, 0.55);
				--cream-border: rgba(236, 225, 199, 0.12);
			}
			main {
				position: relative;
			}
			main::before {
				content: '';
				position: absolute;
				inset: -2rem -10% auto -10%;
				height: 360px;
				background:
					radial-gradient(ellipse 60% 100% at 30% 20%, rgba(236, 200, 140, 0.10), transparent 70%),
					radial-gradient(ellipse 50% 80% at 80% 0%, rgba(220, 180, 120, 0.06), transparent 70%);
				pointer-events: none;
				z-index: -1;
			}

			.hero {
				padding: 4rem 0 3.5rem;
			}
			.hero-tag {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.7rem;
				color: var(--cream-faint);
				padding: 0.32rem 0.75rem;
				background: rgba(236, 225, 199, 0.04);
				border: 1px solid var(--cream-border);
				border-radius: 999px;
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				margin-bottom: 2rem;
				letter-spacing: 0.05em;
			}
			.dot {
				width: 6px; height: 6px; border-radius: 50%;
				background: #6ee7b7;
				box-shadow: 0 0 10px rgba(110, 231, 183, 0.65);
				animation: pulse 3s ease-in-out infinite;
			}
			@keyframes pulse {
				0%, 100% { opacity: 1; }
				50% { opacity: 0.5; }
			}

			.hero h1 {
				font-size: clamp(2.4rem, 6.5vw, 3.6rem);
				letter-spacing: -0.05em;
				font-weight: 300;
				line-height: 1.08;
				margin: 0 0 1.5rem;
				display: flex;
				flex-direction: column;
				gap: 0.1em;
			}
			.hero h1 .line {
				display: block;
				color: var(--cream);
				text-shadow: 0 1px 24px rgba(236, 200, 140, 0.08);
			}
			.hero h1 .line.dim {
				color: var(--cream-soft);
				opacity: 0.78;
				font-style: italic;
				letter-spacing: -0.04em;
			}

			.hero-sub {
				font-size: 1rem;
				color: var(--cream-faint);
				max-width: 540px;
				margin: 0 0 2rem;
			}
			.hero-rule {
				width: 60px;
				height: 1px;
				background: linear-gradient(90deg, rgba(236, 225, 199, 0.35), transparent);
			}

			.posts { margin-top: 1.5rem; }

			.section-head {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 1.25rem;
				font-size: 0.7rem;
				color: var(--text-faint);
				text-transform: lowercase;
				letter-spacing: 0.12em;
			}
			.section-head .rule {
				flex: 1;
				height: 1px;
				background: var(--glass-border);
			}
			.section-head .count { font-variant-numeric: tabular-nums; }

			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				background: var(--glass-bg);
				border: 1px solid var(--glass-border);
				border-radius: var(--radius);
				backdrop-filter: blur(var(--glass-blur)) saturate(140%);
				-webkit-backdrop-filter: blur(var(--glass-blur)) saturate(140%);
				box-shadow: var(--glass-shadow);
				overflow: hidden;
			}
			li + li {
				border-top: 1px solid var(--glass-border);
			}
			li a {
				display: block;
				padding: 1.15rem 1.35rem;
				border: 0;
				transition: background 0.25s ease, padding-left 0.25s ease;
				position: relative;
			}
			li a::before {
				content: '';
				position: absolute;
				left: 0;
				top: 0;
				bottom: 0;
				width: 2px;
				background: var(--text-color);
				opacity: 0;
				transition: opacity 0.25s ease;
			}
			li a:hover {
				background: var(--glass-bg-strong);
				padding-left: 1.6rem;
				border: 0;
			}
			li a:hover::before { opacity: 0.6; }

			.row {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
			}
			.row-title {
				font-size: 1rem;
				color: var(--text-color);
				font-weight: 500;
			}
			.row-date {
				font-size: 0.72rem;
				color: var(--text-faint);
				white-space: nowrap;
				font-variant-numeric: tabular-nums;
				letter-spacing: 0.04em;
			}
			.row-desc {
				margin: 0.4rem 0 0;
				font-size: 0.85rem;
				color: var(--text-secondary);
				line-height: 1.6;
			}

			@media (max-width: 540px) {
				.row { flex-direction: column; gap: 0.25rem; }
				li a:hover { padding-left: 1.35rem; }
			}
		</style>
	</body>
</html>
