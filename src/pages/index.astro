---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-tag">
					<span class="dot"></span>
					<span>{SITE_TITLE.toLowerCase()} // notes</span>
				</div>
				<h1>terminal thoughts.</h1>
				<p class="hero-sub">{SITE_DESCRIPTION}</p>
			</section>

			<section class="posts">
				<div class="section-head">
					<span class="label">recent</span>
					<span class="rule"></span>
					<span class="count">{posts.length.toString().padStart(2, '0')}</span>
				</div>

				<ul>
					{posts.map((post) => (
						<li>
							<a href={`${base}/blog/${post.id}/`}>
								<div class="row">
									<span class="row-title">{post.data.title}</span>
									<span class="row-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</div>
								{post.data.description && (
									<p class="row-desc">{post.data.description}</p>
								)}
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />

		<style>
			.hero {
				padding: 3rem 0 3.5rem;
			}
			.hero-tag {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.75rem;
				color: var(--text-faint);
				padding: 0.3rem 0.7rem;
				background: var(--glass-bg);
				border: 1px solid var(--glass-border);
				border-radius: 999px;
				backdrop-filter: blur(12px);
				-webkit-backdrop-filter: blur(12px);
				margin-bottom: 1.5rem;
			}
			.dot {
				width: 6px; height: 6px; border-radius: 50%;
				background: #6ee7b7;
				box-shadow: 0 0 8px rgba(110, 231, 183, 0.6);
			}
			.hero h1 {
				font-size: clamp(2.25rem, 6vw, 3.25rem);
				letter-spacing: -0.05em;
				font-weight: 400;
				line-height: 1.05;
				margin: 0 0 1rem;
			}
			.hero-sub {
				font-size: 1rem;
				color: var(--text-secondary);
				max-width: 540px;
				margin: 0;
			}

			.posts { margin-top: 1rem; }

			.section-head {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				margin-bottom: 1.25rem;
				font-size: 0.75rem;
				color: var(--text-faint);
				text-transform: lowercase;
				letter-spacing: 0.08em;
			}
			.section-head .rule {
				flex: 1;
				height: 1px;
				background: var(--glass-border);
			}

			ul {
				list-style: none;
				padding: 0;
				margin: 0;
				background: var(--glass-bg);
				border: 1px solid var(--glass-border);
				border-radius: var(--radius);
				backdrop-filter: blur(var(--glass-blur)) saturate(140%);
				-webkit-backdrop-filter: blur(var(--glass-blur)) saturate(140%);
				box-shadow: var(--glass-shadow);
				overflow: hidden;
			}
			li + li {
				border-top: 1px solid var(--glass-border);
			}
			li a {
				display: block;
				padding: 1.1rem 1.25rem;
				border: 0;
				transition: background 0.2s ease;
			}
			li a:hover {
				background: var(--glass-bg-strong);
				border: 0;
			}
			.row {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
			}
			.row-title {
				font-size: 1rem;
				color: var(--text-color);
				font-weight: 500;
			}
			.row-date {
				font-size: 0.75rem;
				color: var(--text-faint);
				white-space: nowrap;
				font-variant-numeric: tabular-nums;
			}
			.row-desc {
				margin: 0.4rem 0 0;
				font-size: 0.85rem;
				color: var(--text-secondary);
				line-height: 1.55;
			}

			@media (max-width: 540px) {
				.row { flex-direction: column; gap: 0.25rem; }
			}
		</style>
	</body>
</html>
